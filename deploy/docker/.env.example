# ==============================
# 基础配置
# ==============================
# Compose 项目名，会影响容器名前缀和默认网络名。
COMPOSE_PROJECT_NAME=robot-mediaserver
# Java 服务镜像名前缀，例如 robot/media-service:latest。
IMAGE_PREFIX=robot
# Java 服务镜像 tag。
IMAGE_TAG=latest
# Java 服务 Docker 镜像使用的运行时基础镜像。必须包含 Java 17、ffmpeg、ffprobe，用于 HLS 切片和视频信息探测。
JAVA_RUNTIME_IMAGE=robot/java17-ffmpeg-runtime:latest
# 目标服务器 CPU 架构：amd64 或 arm64。
TARGET_ARCH=amd64
# Docker 平台值。amd64 对应 linux/amd64，arm64 对应 linux/arm64。
TARGET_PLATFORM=linux/amd64
# 容器时区。
TZ=Asia/Shanghai
# Compose 网络名。
DOCKER_NETWORK=robot-mediaserver
# 部署网络模式：bridge 为默认 Docker bridge；host 不创建 Docker bridge，适合 OpenStack 等对 Docker 路由敏感的 Linux 服务器。host 模式仅建议 Linux 服务器使用。
DEPLOY_NETWORK_MODE=bridge
# Compose bridge 子网。必须选择一个不在服务器 ip route/内网/VPN 中出现的网段，避免 Docker 路由抢占服务器网络。
DOCKER_NETWORK_SUBNET=10.253.10.0/24
# 服务器宿主机运行目录，Java 包、配置、Nginx 静态资源都会安装到这里。~ 表示当前用户目录。
APP_WORKSPACE_ROOT=~/mounts/media
# 安装模式：skip_existing 表示已存在文件/目录不覆盖；overwrite 表示覆盖升级。
INSTALL_MODE=skip_existing

# ==============================
# 服务端口
# ==============================
# 媒体服务对外端口。
MEDIA_SERVICE_PORT=8088
# 控制服务对外端口。
CONTROL_SERVICE_PORT=8082
# 大屏 BFF 对外端口。
BIGSCREEN_BFF_PORT=8090
# 是否开启 Java 远程调试。生产环境建议保持 false。
JAVA_DEBUG_ENABLED=false
# 媒体服务 Java 调试宿主机端口。
MEDIA_SERVICE_DEBUG_PORT=5005
# 控制服务 Java 调试宿主机端口。
CONTROL_SERVICE_DEBUG_PORT=5006
# 大屏 BFF Java 调试宿主机端口。
BIGSCREEN_BFF_DEBUG_PORT=5007

# ==============================
# Nginx 配置
# ==============================
# Nginx 镜像名，需要提前放入 tool-images/<arch>。
NGINX_IMAGE=nginx:alpine
# Nginx HTTP 端口。
NGINX_HTTP_PORT=80
# Nginx 测试/备用 HTTP 端口。
NGINX_ALT_HTTP_PORT=280
# Nginx HTTPS 端口。
NGINX_HTTPS_PORT=4443
# Nginx 测试/备用 HTTPS 端口。
NGINX_ALT_HTTPS_PORT=24443
# 生成自签证书时使用的 IP 或域名。
NGINX_TLS_HOST=localhost
# Nginx 反向代理媒体服务的上游地址，格式 host:port。
NGINX_MEDIA_SERVICE_UPSTREAM=host.docker.internal:8088
# Nginx 反向代理大屏 BFF 的上游地址，格式 host:port。
NGINX_BIGSCREEN_BFF_UPSTREAM=host.docker.internal:8090
# Nginx 反向代理 LiveKit 的上游地址，格式 host:port。
NGINX_LIVEKIT_UPSTREAM=host.docker.internal:7880
# Nginx 测试/备用媒体服务上游地址。
NGINX_MEDIA_SERVICE_TEST_UPSTREAM=host.docker.internal:28088
# Nginx 测试/备用大屏 BFF 上游地址。
NGINX_BIGSCREEN_BFF_TEST_UPSTREAM=host.docker.internal:28090
# Nginx 测试/备用 LiveKit 上游地址。
NGINX_LIVEKIT_TEST_UPSTREAM=host.docker.internal:7880

# ==============================
# TTS 容器配置
# ==============================
# TTS 镜像名，需要提前放入 tool-images/<arch>。
TTS_IMAGE=local/sherpa-tts-http:zh-en
# TTS 服务宿主机端口，容器内端口固定为 8080。
TTS_PORT=5050
# TTS 容器内输出目录。
TTS_OUTPUT_ROOT=/data/tts
# 单次 TTS 请求最大文本长度。
TTS_MAX_TEXT_LENGTH=1000
# 媒体服务调用 TTS 引擎的地址。Compose 内推荐使用 http://tts:8080/api/tts。
TTS_ENGINE_URL=http://tts:8080/api/tts
# 是否启用 TTS Compose profile。默认留空不启动 TTS；需要启动 TTS 时设置为 tts。
COMPOSE_PROFILES=

# ==============================
# MySQL / Redis / Elasticsearch
# ==============================
# MySQL JDBC 连接地址。createDatabaseIfNotExist=true 用于首次部署时自动创建 robot_media 数据库，前提是账号有建库权限。
MYSQL_URL=jdbc:mysql://host.docker.internal:3307/robot_media?createDatabaseIfNotExist=true&useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
# MySQL 用户名。
MYSQL_USERNAME=root
# MySQL 密码。
MYSQL_PASSWORD=root
# Redis 主机地址。
REDIS_HOST=host.docker.internal
# Redis 端口。
REDIS_PORT=6380
# Elasticsearch 地址，多个地址按 Spring Boot 支持的格式填写。
ELASTICSEARCH_URIS=http://host.docker.internal:9200

# ==============================
# LiveKit 配置
# ==============================
# 媒体服务访问 LiveKit 的地址。容器内可用 ws://livekit-server:7880，对外可用 ws://服务器IP:7880。
LIVEKIT_URL=ws://host.docker.internal:7880
# LiveKit API Key。
LIVEKIT_API_KEY=devkey
# LiveKit API Secret，生产环境必须替换。
LIVEKIT_API_SECRET=dev-secret-dev-secret-dev-secret-32
# LiveKit Server 镜像名，需要提前放入 tool-images/<arch>。
LIVEKIT_SERVER_IMAGE=livekit/livekit-server:latest
# LiveKit Egress 镜像名，需要提前放入 tool-images/<arch>。
LIVEKIT_EGRESS_IMAGE=livekit/egress:latest
# LiveKit HTTP/API 端口。
LIVEKIT_HTTP_PORT=7880
# LiveKit RTC TCP 端口。
LIVEKIT_RTC_TCP_PORT=7881
# LiveKit RTC UDP 端口范围起始值。
LIVEKIT_RTC_PORT_RANGE_START=50000
# LiveKit RTC UDP 端口范围结束值。
LIVEKIT_RTC_PORT_RANGE_END=50100
# 是否自动使用外部 IP。
LIVEKIT_USE_EXTERNAL_IP=false
# LiveKit 日志级别。
LIVEKIT_LOG_LEVEL=info
# LiveKit Server 使用的 Redis 地址，格式 host:port。
LIVEKIT_REDIS_ADDRESS=host.docker.internal:6380
# LiveKit Server 使用的 Redis 用户名，可为空。
LIVEKIT_REDIS_USERNAME=
# LiveKit Server 使用的 Redis 密码，可为空。
LIVEKIT_REDIS_PASSWORD=
# LiveKit Server 使用的 Redis DB。
LIVEKIT_REDIS_DB=1
# LiveKit 节点 IP。容器部署且需要其他电脑浏览器播放视频时，建议填写服务器局域网 IP，例如 192.168.124.77，避免浏览器拿到容器内网 IP。
LIVEKIT_NODE_IP=
# LiveKit Egress 连接 LiveKit Server 的 WebSocket 地址。
LIVEKIT_EGRESS_WS_URL=ws://livekit-server:7880
# LiveKit Egress 使用的 Redis 地址，格式 host:port。
LIVEKIT_EGRESS_REDIS_ADDRESS=host.docker.internal:6380
# LiveKit Egress 使用的 Redis 用户名，可为空。
LIVEKIT_EGRESS_REDIS_USERNAME=
# LiveKit Egress 使用的 Redis 密码，可为空。
LIVEKIT_EGRESS_REDIS_PASSWORD=
# LiveKit Egress 使用的 Redis DB。
LIVEKIT_EGRESS_REDIS_DB=1

# ==============================
# MinIO / S3 配置
# ==============================
# MinIO/S3 地址。
MINIO_ENDPOINT=http://host.docker.internal:9000
# MinIO/S3 Access Key。
MINIO_ACCESS_KEY=eiopminio
# MinIO/S3 Secret Key。
MINIO_SECRET_KEY=eiopminio123
# 媒体文件桶名。
MINIO_BUCKET=robot-media

# ==============================
# MQTT 配置
# ==============================
# 是否启用 MQTT。
MQTT_ENABLED=true
# MQTT Broker 地址。
MQTT_BROKER_URL=tcp://host.docker.internal:1884
# MQTT 用户名，可为空。
MQTT_USERNAME=
# MQTT 密码，可为空。
MQTT_PASSWORD=
# 控制服务连接 MQTT 时使用的客户端 ID。
MQTT_CLIENT_ID=robot-control-service-main

# ==============================
# 大屏 BFF / 中心服务配置
# ==============================
# 管理中心服务基础地址。
CENTER_MANAGE_BASE_URL=http://host.docker.internal:8866
# 控制服务基础地址。Compose 内推荐使用 http://control-service:8082。
CENTER_CONTROL_BASE_URL=http://control-service:8082
# 旧版控制服务基础地址。
CENTER_V1_CONTROL_BASE_URL=http://host.docker.internal:8867
# 媒体服务基础地址。Compose 内推荐使用 http://media-service:8088。
CENTER_MEDIA_BASE_URL=http://media-service:8088
# 控制服务 WebSocket 地址。
CENTER_CONTROL_WS_URL=ws://control-service:8082/ws/control
# 大屏接口允许跨域访问的来源模式，多个值用逗号分隔。
BIGSCREEN_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:8080,http://127.0.0.1:8080,http://192.168.*.*:8080,https://192.168.*.*:4443
