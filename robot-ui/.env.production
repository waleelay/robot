# 页面标题
VUE_APP_TITLE=具身智能平台指挥中心

# 生产环境标识
NODE_ENV=production

# 反向代理路径（由 Nginx 处理到后端）
#VUE_APP_BASE_API=/prod-api
#VUE_APP_BASE_IP=http://192.168.1.2:8080
#VUE_APP_WEBRTC=http://192.168.1.2:8000/api
#VUE_APP_VOICEWEBSOCKET_URL=ws://192.168.1.2:10000/voice
#VUE_APP_WEBSOCKET_URL=ws://192.168.1.2:8080/websocket
#VUE_APP_YUNTAI_CONTROL=http://192.168.1.2:8093/Hik/yunTaiControlAll

# 前端访问接口地址（走 nginx）
VUE_APP_BASE_API=

# 实际拼接的全路径访问地址（也必须是 HTTPS）
VUE_APP_BASE_IP=https://10.2.75.230

# webrtc 本身如果无关紧要可以忽略，否则你也可以代理一条
VUE_APP_WEBRTC=https://10.2.75.230/webrtc

# WebSocket，必须用 wss，走 nginx 代理
VUE_APP_VOICEWEBSOCKET_URL=wss://10.2.75.230/voice

# 第二个 WebSocket 一样处理
VUE_APP_WEBSOCKET_URL=wss://10.2.75.230/websocket

# 云台控制接口也可以通过 nginx 代理
VUE_APP_YUNTAI_CONTROL=https://10.2.75.230/yuntai


VUE_APP_WS_URL = wss://192.168.124.77:4443/ws/control
